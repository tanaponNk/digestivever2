# Google Apps Script Web App URL
# สำหรับบันทึกข้อมูลผู้เล่นและดึงข้อมูล Ranking ไปยัง Google Sheets
#
# วิธีใช้:
#   - ถ้ารันบน server (Node/Python) ให้อ่านค่านี้แล้ว inject เป็น window.APP_CONFIG ใน HTML
#   - ถ้าใช้ผ่าน Element Platform ให้ตั้งค่าใน Admin Config Panel ด้วย key: sheet_url
#
# ห้าม commit ไฟล์นี้ขึ้น Git (เพิ่มใน .gitignore)

SHEET_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/exec
